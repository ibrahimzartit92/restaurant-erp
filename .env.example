POSTGRES_DB=restaurant_erp
POSTGRES_USER=restaurant_user
POSTGRES_PASSWORD=restaurant_password
POSTGRES_PORT=5432

API_PORT=3001
WEB_PORT=3000
NGINX_PORT=8080

# Server-side Next.js requests from the web container to the API container.
INTERNAL_API_URL=http://api:3001

# Browser-side requests. For local Docker keep localhost when opening the web app on port 3000.
# On VPS set this to a browser-reachable API origin, or /api when Nginx proxies /api/* to the API.
# Example VPS values: https://api.example.com, https://example.com, or /api
NEXT_PUBLIC_API_URL=http://localhost:3001

JWT_SECRET=change_this_secret_before_production
JWT_EXPIRES_IN=1d

POSTGRES_DB=restaurant_erp
POSTGRES_USER=restaurant_user
POSTGRES_PASSWORD=restaurant_password
POSTGRES_PORT=5432

API_PORT=3001
WEB_PORT=3000
NGINX_PORT=8080

# Server-side Next.js requests from the web container to the API container.
INTERNAL_API_URL=http://api:3001

# Browser-side requests go through the same-origin frontend proxy by default.
# Keep /api unless you intentionally want direct browser-to-API requests.
NEXT_PUBLIC_API_URL=/api

JWT_SECRET=change_this_secret_before_production
JWT_EXPIRES_IN=1d
